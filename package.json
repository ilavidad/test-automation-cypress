{
  "name": "test-automation-cypress",
  "version": "1.0.0",
  "description": "Cypress and Cucumber end-to-end automation suite for OpenCart demo user flows.",
  "scripts": {
    "test": "node scripts/run-cypress.js run",
    "dev": "node scripts/run-cypress.js open",
    "test:login": "node scripts/run-cypress.js run --spec cypress/e2e/features/login.feature",
    "test:add-to-cart": "node scripts/run-cypress.js run --spec cypress/e2e/features/add-to-cart.feature",
    "test:compare": "node scripts/run-cypress.js run --spec cypress/e2e/features/compare-products.feature",
    "validate:env": "node scripts/validate-env.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "keywords": [],
  "author": "Anais Molina",
  "license": "ISC",
  "type": "commonjs",
  "devDependencies": {
    "@badeball/cypress-cucumber-preprocessor": "^24.0.1",
    "@bahmutov/cypress-esbuild-preprocessor": "^2.2.8",
    "cypress": "^15.13.1",
    "eslint": "^10.2.0",
    "globals": "^17.4.0",
    "prettier": "^3.8.1"
  }
}
